{
  "name": "dihemapp",
  "private": true,
  "version": "1.1.0",
  "description": "منصة تعليمية متكاملة للأستاذ الجزائري لتوليد الاختبارات والمذكرات وإدارة الملاحظات.",
  "author": "dihem",
  "repository": {
    "type": "git",
    "url": "https://github.com/farisdihem/dihemabd.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "electron:start": "electron .",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "dist": "vite build && electron-builder --win appx",
    "preview": "vite preview",
    "clean": "rm -rf dist release dist-electron",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "katex": "^0.16.44",
    "lucide-react": "^0.546.0",
    "marked": "^17.0.5",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5",
    "xlsx-populate": "^1.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/katex": "^0.16.8",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "dihemabd.dihem1",
    "productName": "مولد المذكرات",
    "icon": "electron/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "appx",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "appx": {
      "identityName": "dihemabd.dihem1",
      "publisher": "CN=A0215202-1978-4547-B989-BCD810C21B84",
      "publisherDisplayName": "dihem abd",
      "applicationId": "App",
      "backgroundColor": "#ffffff"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
